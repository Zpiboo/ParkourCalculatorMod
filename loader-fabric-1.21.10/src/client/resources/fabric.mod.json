{
	"schemaVersion": 1,
	"id": "parkourcalculator",
	"version": "${version}",
	"name": "Parkour Calculator",
	"description": "TAS input planner for Minecraft parkour: edit inputs tick-by-tick and visualize the predicted player path in-world.",
	"authors": [
		"Legoshi"
	],
	"contact": {
		"homepage": "https://github.com/Leg0shii/ParkourCalculatorMod",
		"sources": "https://github.com/Leg0shii/ParkourCalculatorMod",
		"issues": "https://github.com/Leg0shii/ParkourCalculatorMod/issues"
	},
	"license": "CC0-1.0",
	"environment": "client",
	"entrypoints": {
		"client": [
			"de.legoshi.parkourcalc.fabric.FabricParkourCalculator"
		]
	},
	"mixins": [
		{
			"config": "parkourcalculator.client.mixins.json",
			"environment": "client"
		}
	],
	"accessWidener": "parkourcalculator.accesswidener",
	"depends": {
		"fabricloader": ">=0.16.14",
		"minecraft": "~1.21.10",
		"java": ">=21",
		"fabric-api": "*"
	}
}
